        "from sklearn.metrics import confusion_matrix\n",
        "\n",
        "def generate_confusion_matrix_visualization(clf, val_dl):\n",
        "\n",
        "    device = DEVICE\n",
        "\n",
        "    CATEGORIES = ['apple', 'baseballbat', 'basketball', 'clock', 'compass',\n",
        "                  'cookie', 'donut', 'ladder', 'mountain', 'pizza',\n",
        "                  'rabbit', 'soccerball', 'spider', 't-shirt', 'wheel']\n",
        "\n",
        "    clf = clf.to(device)\n",
        "    clf.eval()\n",
        "\n",
        "    all_pred_labels = []\n",
        "    all_true_labels = []\n",
        "\n",
        "    print(\"Computing predictions for confusion matrix...\")\n",
        "    with torch.no_grad():\n",
        "        for batch_imgs, batch_labels in val_dl:\n",
        "            batch_imgs = batch_imgs.to(device)\n",
        "            logits = clf(batch_imgs)\n",
        "            _, pred_labels = torch.max(logits.data, 1)\n",
        "\n",
        "            all_pred_labels.extend(pred_labels.cpu().numpy())\n",
        "            all_true_labels.extend(batch_labels.cpu().numpy())\n",
        "\n",
        "    # Build confusion matrix\n",
        "    confusion_data = confusion_matrix(all_true_labels, all_pred_labels)\n",
        "\n",
        "    # Visualization\n",
        "    plt.figure(figsize=(10, 8))\n",
        "    sns.heatmap(confusion_data, annot=True, fmt='d', cmap='Blues',\n",
        "                xticklabels=CATEGORIES, yticklabels=CATEGORIES)\n",
        "    plt.xlabel('Predicted Class', fontsize=12, fontweight='bold')\n",
