        "# Load test dataset\n",
        "test_data = DrawingDataset(TEST_FILE, split='test')\n",
        "test_loader = DataLoader(test_data, batch_size=BATCH_SIZE, shuffle=False)\n",
        "\n",
        "def infer_and_submit(net, checkpoint_path, data_loader, output_path):\n",
        "    \"\"\"\n",
        "    Load model weights and generate predictions on test set.\n",
        "\n",
        "    Parameters:\n",
        "        net: Model architecture\n",
        "        checkpoint_path: Path to saved weights\n",
        "        data_loader: Test dataloader\n",
        "        output_path: Output submission file path\n",
        "\n",
        "    Returns:\n",
        "        list: Predicted class labels\n",
        "    \"\"\"\n",
        "    net.load_state_dict(torch.load(checkpoint_path))\n",
        "    net.eval()\n",
        "    net.to(DEVICE)\n",
        "\n",
        "    predictions = []\n",
        "    with torch.no_grad():\n",
        "        for batch in data_loader:\n",
        "            samples = batch.to(DEVICE)\n",
        "            outputs = net(samples)\n",
        "            _, pred_classes = torch.max(outputs, 1)\n",
        "            predictions.extend(pred_classes.cpu().numpy())\n",
        "\n",
        "    with open(output_path, \"w\") as f:\n",
        "        f.write(\",\".join(map(str, predictions)))\n",
        "\n",
        "    print(f\"-> Predictions saved to {output_path}\")\n",
        "    return predictions\n"
