      "source": [
        "class ChampionMLP(nn.Module):\n",
        "\n",
        "    def __init__(self, input_dim=784, output_dim=15):\n",
        "        super(ChampionMLP, self).__init__()\n",
        "        self.network = nn.Sequential(\n",
        "            nn.Linear(input_dim, 512),\n",
        "            nn.BatchNorm1d(512),\n",
        "            nn.GELU(),\n",
        "            nn.Dropout(0.2),\n",
        "\n",
        "            nn.Linear(512, 256),      # smoother compression than 512→384→128\n",
        "            nn.BatchNorm1d(256),\n",
        "            nn.GELU(),\n",
        "            nn.Dropout(0.2),\n",
        "\n",
        "            nn.Linear(256, 128),\n",
        "            nn.BatchNorm1d(128),\n",
        "            nn.GELU(),\n",
        "            nn.Dropout(0.1),          # less dropout near classifier\n",
        "\n",
        "            nn.Linear(128, 64),       # gentle final compression\n",
        "            nn.BatchNorm1d(64),\n",
        "            nn.GELU(),\n",
        "\n",
        "            nn.Linear(64, output_dim)\n",
        "        )\n",
        "\n",
        "    def forward(self, x):\n",
        "        x = x.reshape(x.size(0), -1)\n",
        "        return self.network(x)\n"
