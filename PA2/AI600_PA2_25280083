        "import torch\n",
        "import torch.nn as nn\n",
        "import torch.optim as optim\n",
        "import torchvision.transforms as T\n",
        "\n",
        "def execute_training(model, train_dl, val_dl, num_epochs=30, model_id='model'):\n",
        "\n",
        "    device = DEVICE\n",
        "    model = model.to(device)\n",
        "\n",
        "    # Setting loss & optimization\n",
        "    loss_fn = nn.CrossEntropyLoss(label_smoothing=0.1)\n",
        "    optimizer = optim.AdamW(model.parameters(), lr=1e-3, weight_decay=1e-4)\n",
        "\n",
        "    scheduler = optim.lr_scheduler.OneCycleLR(\n",
        "        optimizer,\n",
        "        max_lr=3e-3,\n",
        "        steps_per_epoch=len(train_dl),\n",
        "        epochs=num_epochs,\n",
        "        pct_start=0.2\n",
        "    )\n",
        "\n",
        "    #Augmentation\n",
        "    spatial_transform = T.RandomAffine(degrees=10, translate=(0.08, 0.08))\n",
        "    metrics = {'train_acc': [], 'val_acc': [], 'train_loss': [], 'val_loss': []}\n",
        "\n",
        "    for ep in range(num_epochs):\n",
        "        # ===== Training Phase =====\n",
        "        model.train()\n",
        "        tr_loss, tr_correct, tr_count = 0.0, 0, 0\n",
        "\n",
        "        for imgs, targets in train_dl:\n",
        "            # Apply spatial transformation\n",
        "            imgs_2d = imgs.view(-1, 1, 28, 28)\n",
        "            imgs_transformed = spatial_transform(imgs_2d)\n",
        "            imgs = imgs_transformed.view(-1, 784).to(device)\n",
        "            targets = targets.to(device)\n",
        "\n",
        "            optimizer.zero_grad()\n",
        "            logits = model(imgs)\n",
        "            loss = loss_fn(logits, targets)\n",
        "            loss.backward()\n",
        "            optimizer.step()\n",
        "            scheduler.step()\n",
        "\n",
        "            tr_loss += loss.item() * imgs.size(0)\n",
        "            _, pred = torch.max(logits.data, 1)\n",
        "            tr_count += targets.size(0)\n",
        "            tr_correct += (pred == targets).sum().item()\n",
        "\n",
        "        acc_train = 100 * tr_correct / tr_count\n",
        "        loss_train = tr_loss / tr_count\n",
        "\n",
        "\n",
        "        # ===== Validation Phase =====\n",
        "        model.eval()\n",
        "        val_correct, val_count = 0, 0\n",
        "        val_loss_sum = 0.0\n",
        "\n",
        "        with torch.no_grad():\n",
        "            for imgs, targets in val_dl:\n",
        "                imgs, targets = imgs.to(device), targets.to(device)\n",
        "\n",
        "                logits = model(imgs)\n",
        "                _, pred = torch.max(logits.data, 1)\n",
        "                val_count += targets.size(0)\n",
        "                val_correct += (pred == targets).sum().item()\n",
        "                loss = loss_fn(logits, targets)\n",
        "                val_loss_sum += loss.item() * imgs.size(0)\n",
        "\n",
        "        acc_val = 100 * val_correct / val_count\n",
        "        loss_val = val_loss_sum / val_count\n",
        "\n",
        "        print(f\"Epoch [{ep+1}/{num_epochs}] | Train Acc: {acc_train:.2f}% | Val Acc: {acc_val:.2f}%\")\n",
        "\n",
        "        metrics['train_acc'].append(acc_train)\n",
        "        metrics['val_acc'].append(acc_val)\n",
        "        metrics['train_loss'].append(loss_train)\n",
        "        metrics['val_loss'].append(loss_val)\n",
        "\n",
        "    torch.save(model.state_dict(), f\"{model_id}_weights.pth\")\n",
        "    print(\"Training finished. Model saved.\")\n",
        "    return metrics\n"
      ],
