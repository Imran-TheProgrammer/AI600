        "class DrawingDataset(Dataset):\n",
        "\n",
        "    def __init__(self, npz_path, split='train'):\n",
        "\n",
        "        self.split = split\n",
        "\n",
        "        if not os.path.exists(npz_path):\n",
        "            raise FileNotFoundError(f\"Archive not found: {npz_path}\")\n",
        "\n",
        "        print(f\"Reading {split} data from archive: {npz_path}...\")\n",
        "        archive = np.load(npz_path)\n",
        "\n",
        "        if split == 'train':\n",
        "            self.images = archive['x_train']\n",
        "            self.labels = archive['y_train']\n",
        "            self.class_list = archive['class_names']\n",
        "            print(f\"Loaded {len(self.images)} training samples. Total classes: {len(self.class_list)}\")\n",
        "\n",
        "        elif split == 'test':\n",
        "            self.images = archive['test_images']\n",
        "            self.labels = None\n",
        "            print(f\"Loaded {len(self.images)} test images.\")\n",
        "\n",
        "        # Normalize pixel values\n",
        "        self.images = torch.from_numpy(self.images).float() / 255.0\n",
        "\n",
        "        if self.labels is not None:\n",
        "            self.labels = torch.from_numpy(self.labels).long()\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.images)\n",
        "\n",
        "    def __getitem__(self, index):\n",
        "        sketch = self.images[index]\n",
        "        if self.split == 'train':\n",
        "            target = self.labels[index]\n",
        "            return sketch, target\n",
        "        else:\n",
        "            return sketch"
